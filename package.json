{
  "name": "pharmacy-mgmt-backend",
  "version": "1.0.0",
  "description": "Pharmacy management system backend (Express + TypeScript + MongoDB).",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "concurrently -k -n tsc,api -c blue,green \"tsc --watch\" \"nodemon -q dist/index.js\"",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "check": "npm run lint && npm run check-types",
    "prepare": "husky install",
    "seed": "node seeders/seed.all.js",
    "seed:units": "node seeders/seed.units.js",
    "seed:formulations": "node seeders/seed.formulations.js",
    "seed:groups": "node seeders/seed.groups.js",
    "seed:manufacturers": "node seeders/seed.manufacturers.js",
    "seed:generics": "node seeders/seed.generics.js",
    "seed:brands": "node seeders/seed.brands.js",
    "seed:drugs": "node seeders/seed.drugs.js",
    "seed:staff": "node seeders/seed.staff.js",
    "seed:users": "node seeders/seed.users.js",
    "seed:suppliers": "node seeders/seed.suppliers.js",
    "seed:purchases": "node seeders/seed.purchases.js",
    "seed:sales": "node seeders/seed.sales.js",
    "seed:salaries": "node seeders/seed.salaries.js",
    "seed:attendances": "node seeders/seed.attendances.js"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix",
    "seeders/**/*.js": "eslint --fix"
  },
  "keywords": [
    "pharmacy",
    "express",
    "typescript",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "http-status": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.2",
    "nodemailer": "^6.9.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.1.2",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.10",
    "nodemon": "^3.1.9",
    "prettier": "^3.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  }
}
